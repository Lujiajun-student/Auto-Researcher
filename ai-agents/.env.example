# DeepSeek AI 配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.5

# AI Agent 温度配置
DEEPSEEK_TEMPERATURE_ORCHESTRATOR=0.3
DEEPSEEK_TEMPERATURE_SEARCH=0.3
DEEPSEEK_TEMPERATURE_RAG=0.4
DEEPSEEK_TEMPERATURE_CODE=0.7

# arXiv API 配置
ARXIV_API_KEY=your_arxiv_api_key_here

# 长期记忆配置
MEMORY_STORAGE_PATH=./data/long_term_memory.json
MEMORY_MAX_RETRIEVALS=3

# 服务配置
HOST=0.0.0.0
PORT=8000
